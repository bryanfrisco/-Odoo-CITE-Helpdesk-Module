<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ====== Lokasi — hanya Head Office & Site (berlaku lintas company) ====== -->
        <record id="site_ho_a" model="cite.site">
            <field name="name">Head Office</field>
            <field name="code">HO</field>
            <field name="site_type">ho</field>
            <field name="company_id" eval="False"/>
            <field name="sequence">1</field>
        </record>
        <record id="site_st_a" model="cite.site">
            <field name="name">Site</field>
            <field name="code">ST</field>
            <field name="site_type">site</field>
            <field name="company_id" eval="False"/>
            <field name="sequence">2</field>
        </record>

        <!-- ====== Categories (Bab 7.4) ====== -->
        <record id="cat_software" model="cite.category">
            <field name="name">Software</field>
            <field name="code">SW</field>
            <field name="sequence">10</field>
            <field name="icon">fa-window-restore</field>
            <field name="require_approval" eval="False"/>
            <field name="ticket_type_id" ref="helpdesk_ticket_type_incident"/>
            <field name="knowledge_tag">software</field>
        </record>
        <record id="cat_hardware" model="cite.category">
            <field name="name">Hardware</field>
            <field name="code">HW</field>
            <field name="sequence">20</field>
            <field name="icon">fa-desktop</field>
            <field name="require_approval" eval="False"/>
            <field name="ticket_type_id" ref="helpdesk_ticket_type_incident"/>
            <field name="knowledge_tag">hardware</field>
        </record>
        <record id="cat_network" model="cite.category">
            <field name="name">Network</field>
            <field name="code">NW</field>
            <field name="sequence">30</field>
            <field name="icon">fa-wifi</field>
            <field name="require_approval" eval="False"/>
            <field name="ticket_type_id" ref="helpdesk_ticket_type_incident"/>
            <field name="knowledge_tag">network</field>
        </record>
        <record id="cat_server" model="cite.category">
            <field name="name">Server</field>
            <field name="code">SRV</field>
            <field name="sequence">40</field>
            <field name="icon">fa-server</field>
            <field name="require_approval" eval="True"/>
            <field name="ticket_type_id" ref="helpdesk_ticket_type_service_request"/>
            <field name="knowledge_tag">server</field>
        </record>
        <record id="cat_printer" model="cite.category">
            <field name="name">Printer</field>
            <field name="code">PRN</field>
            <field name="sequence">50</field>
            <field name="icon">fa-print</field>
            <field name="require_approval" eval="False"/>
            <field name="ticket_type_id" ref="helpdesk_ticket_type_incident"/>
            <field name="knowledge_tag">printer</field>
        </record>
        <record id="cat_cctv" model="cite.category">
            <field name="name">CCTV</field>
            <field name="code">CCTV</field>
            <field name="sequence">60</field>
            <field name="icon">fa-video-camera</field>
            <field name="require_approval" eval="False"/>
            <field name="ticket_type_id" ref="helpdesk_ticket_type_incident"/>
            <field name="knowledge_tag">cctv</field>
        </record>
        <record id="cat_access" model="cite.category">
            <field name="name">Access</field>
            <field name="code">ACC</field>
            <field name="sequence">70</field>
            <field name="icon">fa-key</field>
            <field name="require_approval" eval="True"/>
            <field name="ticket_type_id" ref="helpdesk_ticket_type_access_request"/>
            <field name="knowledge_tag">user access</field>
        </record>
        <record id="cat_asset_request" model="cite.category">
            <field name="name">Asset Request</field>
            <field name="code">AST</field>
            <field name="sequence">80</field>
            <field name="icon">fa-cube</field>
            <field name="require_approval" eval="True"/>
            <field name="ticket_type_id" ref="helpdesk_ticket_type_service_request"/>
        </record>

        <!-- ====== Sub Categories ====== -->
        <!-- Software -->
        <record id="sub_sw_odoo" model="cite.subcategory">
            <field name="name">Odoo</field><field name="category_id" ref="cat_software"/>
        </record>
        <record id="sub_sw_office" model="cite.subcategory">
            <field name="name">Microsoft Office</field><field name="category_id" ref="cat_software"/>
        </record>
        <record id="sub_sw_intune" model="cite.subcategory">
            <field name="name">Microsoft Intune</field><field name="category_id" ref="cat_software"/>
        </record>
        <record id="sub_sw_onedrive" model="cite.subcategory">
            <field name="name">Onedrive</field><field name="category_id" ref="cat_software"/>
        </record>
        <record id="sub_sw_email" model="cite.subcategory">
            <field name="name">Email</field><field name="category_id" ref="cat_software"/>
        </record>
        <record id="sub_sw_windows" model="cite.subcategory">
            <field name="name">Windows</field><field name="category_id" ref="cat_software"/>
        </record>
        <record id="sub_sw_installation" model="cite.subcategory">
            <field name="name">Software Installation</field>
            <field name="category_id" ref="cat_software"/>
            <field name="require_approval" eval="True"/>
        </record>
        <record id="sub_sw_license" model="cite.subcategory">
            <field name="name">Software License Request</field>
            <field name="category_id" ref="cat_software"/>
            <field name="require_approval" eval="True"/>
        </record>
        <!-- Hardware -->
        <record id="sub_hw_laptop" model="cite.subcategory">
            <field name="name">Laptop</field><field name="category_id" ref="cat_hardware"/>
        </record>
        <record id="sub_hw_desktop" model="cite.subcategory">
            <field name="name">Desktop</field><field name="category_id" ref="cat_hardware"/>
        </record>
        <record id="sub_hw_monitor" model="cite.subcategory">
            <field name="name">Monitor</field><field name="category_id" ref="cat_hardware"/>
        </record>
        <record id="sub_hw_ups" model="cite.subcategory">
            <field name="name">UPS</field><field name="category_id" ref="cat_hardware"/>
        </record>
        <!-- Network -->
        <record id="sub_nw_internet" model="cite.subcategory">
            <field name="name">Internet</field><field name="category_id" ref="cat_network"/>
        </record>
        <record id="sub_nw_wifi" model="cite.subcategory">
            <field name="name">WiFi</field><field name="category_id" ref="cat_network"/>
        </record>
        <record id="sub_nw_vpn" model="cite.subcategory">
            <field name="name">VPN</field><field name="category_id" ref="cat_network"/>
        </record>
        <record id="sub_nw_switch" model="cite.subcategory">
            <field name="name">Switch</field><field name="category_id" ref="cat_network"/>
        </record>
        <record id="sub_nw_router" model="cite.subcategory">
            <field name="name">Router</field><field name="category_id" ref="cat_network"/>
        </record>
        <!-- Server -->
        <record id="sub_srv_windows" model="cite.subcategory">
            <field name="name">Windows Server</field><field name="category_id" ref="cat_server"/>
        </record>
        <record id="sub_srv_linux" model="cite.subcategory">
            <field name="name">Linux Server</field><field name="category_id" ref="cat_server"/>
        </record>
        <record id="sub_srv_database" model="cite.subcategory">
            <field name="name">Database</field><field name="category_id" ref="cat_server"/>
        </record>
        <record id="sub_srv_backup" model="cite.subcategory">
            <field name="name">Backup</field><field name="category_id" ref="cat_server"/>
        </record>
        <record id="sub_srv_vm" model="cite.subcategory">
            <field name="name">Virtual Machine</field><field name="category_id" ref="cat_server"/>
        </record>
        <!-- Printer -->
        <record id="sub_prn_printer" model="cite.subcategory">
            <field name="name">Printer</field><field name="category_id" ref="cat_printer"/>
        </record>
        <record id="sub_prn_scanner" model="cite.subcategory">
            <field name="name">Scanner</field><field name="category_id" ref="cat_printer"/>
        </record>
        <!-- CCTV -->
        <record id="sub_cctv_camera" model="cite.subcategory">
            <field name="name">Camera</field><field name="category_id" ref="cat_cctv"/>
        </record>
        <record id="sub_cctv_dvr" model="cite.subcategory">
            <field name="name">DVR</field><field name="category_id" ref="cat_cctv"/>
        </record>
        <record id="sub_cctv_nvr" model="cite.subcategory">
            <field name="name">NVR</field><field name="category_id" ref="cat_cctv"/>
        </record>
        <record id="sub_cctv_access" model="cite.subcategory">
            <field name="name">CCTV Access Request</field>
            <field name="category_id" ref="cat_cctv"/>
            <field name="require_approval" eval="True"/>
        </record>
        <!-- Access -->
        <record id="sub_acc_odoo" model="cite.subcategory">
            <field name="name">Odoo Access</field><field name="category_id" ref="cat_access"/>
        </record>
        <record id="sub_acc_email" model="cite.subcategory">
            <field name="name">Email Access</field><field name="category_id" ref="cat_access"/>
        </record>
        <record id="sub_acc_folder" model="cite.subcategory">
            <field name="name">Shared Folder Access</field><field name="category_id" ref="cat_access"/>
        </record>
        <record id="sub_acc_vpn" model="cite.subcategory">
            <field name="name">VPN Access</field><field name="category_id" ref="cat_access"/>
        </record>
        <!-- Asset Request -->
        <record id="sub_ast_laptop" model="cite.subcategory">
            <field name="name">New Laptop</field><field name="category_id" ref="cat_asset_request"/>
        </record>
        <record id="sub_ast_desktop" model="cite.subcategory">
            <field name="name">New Desktop</field><field name="category_id" ref="cat_asset_request"/>
        </record>
        <record id="sub_ast_printer" model="cite.subcategory">
            <field name="name">New Printer</field><field name="category_id" ref="cat_asset_request"/>
        </record>
        <record id="sub_ast_monitor" model="cite.subcategory">
            <field name="name">New Monitor</field><field name="category_id" ref="cat_asset_request"/>
        </record>
        <record id="sub_ast_replacement" model="cite.subcategory">
            <field name="name">Asset Replacement</field><field name="category_id" ref="cat_asset_request"/>
        </record>

    </data>
</odoo>
