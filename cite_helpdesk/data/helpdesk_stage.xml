<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 10 stages (Draft dihilangkan — tiket langsung mulai di Open) -->
        <record id="stage_open" model="helpdesk.stage">
            <field name="name">Open</field>
            <field name="sequence">2</field>
            <field name="fold" eval="False"/>
            <field name="is_close" eval="False"/>
            <field name="team_ids" eval="[(4, ref('helpdesk_team_cite'))]"/>
        </record>
        <record id="stage_pending_admin" model="helpdesk.stage">
            <field name="name">Awaiting Admin Approval</field>
            <field name="sequence">3</field>
            <field name="fold" eval="False"/>
            <field name="is_close" eval="False"/>
            <field name="team_ids" eval="[(4, ref('helpdesk_team_cite'))]"/>
        </record>
        <record id="stage_pending_heidi" model="helpdesk.stage">
            <field name="name">Awaiting Final Approval</field>
            <field name="sequence">4</field>
            <field name="fold" eval="False"/>
            <field name="is_close" eval="False"/>
            <field name="team_ids" eval="[(4, ref('helpdesk_team_cite'))]"/>
        </record>
        <record id="stage_assigned" model="helpdesk.stage">
            <field name="name">Assigned</field>
            <field name="sequence">5</field>
            <field name="fold" eval="False"/>
            <field name="is_close" eval="False"/>
            <field name="team_ids" eval="[(4, ref('helpdesk_team_cite'))]"/>
        </record>
        <record id="stage_in_progress" model="helpdesk.stage">
            <field name="name">In Progress</field>
            <field name="sequence">6</field>
            <field name="fold" eval="False"/>
            <field name="is_close" eval="False"/>
            <field name="team_ids" eval="[(4, ref('helpdesk_team_cite'))]"/>
        </record>
        <record id="stage_waiting_user" model="helpdesk.stage">
            <field name="name">Waiting User</field>
            <field name="sequence">7</field>
            <field name="fold" eval="False"/>
            <field name="is_close" eval="False"/>
            <field name="team_ids" eval="[(4, ref('helpdesk_team_cite'))]"/>
        </record>
        <record id="stage_resolved" model="helpdesk.stage">
            <field name="name">Resolved</field>
            <field name="sequence">8</field>
            <field name="fold" eval="False"/>
            <field name="is_close" eval="False"/>
            <field name="team_ids" eval="[(4, ref('helpdesk_team_cite'))]"/>
        </record>
        <record id="stage_closed" model="helpdesk.stage">
            <field name="name">Closed</field>
            <field name="sequence">9</field>
            <field name="fold" eval="True"/>
            <field name="is_close" eval="True"/>
            <field name="team_ids" eval="[(4, ref('helpdesk_team_cite'))]"/>
        </record>
        <record id="stage_cancelled" model="helpdesk.stage">
            <field name="name">Cancelled</field>
            <field name="sequence">10</field>
            <field name="fold" eval="True"/>
            <field name="is_close" eval="True"/>
            <field name="team_ids" eval="[(4, ref('helpdesk_team_cite'))]"/>
        </record>
        <record id="stage_rejected" model="helpdesk.stage">
            <field name="name">Rejected</field>
            <field name="sequence">11</field>
            <field name="fold" eval="True"/>
            <field name="is_close" eval="True"/>
            <field name="team_ids" eval="[(4, ref('helpdesk_team_cite'))]"/>
        </record>
    </data>
</odoo>
