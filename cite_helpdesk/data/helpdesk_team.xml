<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- FR-01.2 — Single Point of Contact: satu Helpdesk Team -->
        <record id="helpdesk_team_cite" model="helpdesk.team">
            <field name="name">CITE Helpdesk Team</field>
            <field name="cite_team" eval="True"/>
            <!-- Alias terpisah dari helpdesk Stargo. Email-to-ticket: cite@<domain>.
                 Untuk cite@aspire.id, vendor set Alias Domain ke aspire.id di
                 Settings > Technical > Email > Alias Domains (infra, di luar modul). -->
            <field name="alias_name">cite</field>
            <field name="use_sla" eval="True"/>
            <field name="assign_method">balanced</field>
            <field name="privacy_visibility">portal</field>
            <field name="use_website_helpdesk_form" eval="True"/>
            <field name="use_website_helpdesk_knowledge" eval="True"/>
            <field name="use_rating" eval="True"/>
            <field name="portal_show_rating" eval="True"/>
            <field name="description">Single Point of Contact seluruh kebutuhan IT
                (Company A, B, C — Head Office &amp; Site).</field>
        </record>
    </data>
</odoo>
