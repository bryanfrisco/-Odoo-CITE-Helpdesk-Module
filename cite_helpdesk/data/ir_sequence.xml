<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- FR-03.2 — IT-YYYY-XXXXX, reset tahunan, unik global lintas company -->
        <record id="seq_cite_helpdesk_ticket" model="ir.sequence">
            <field name="name">CITE Helpdesk Ticket</field>
            <field name="code">cite.helpdesk.ticket</field>
            <field name="prefix">IT-%(year)s-</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="use_date_range" eval="True"/>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
