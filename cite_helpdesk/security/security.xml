<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ Module Category ============ -->
    <record id="module_category_cite_helpdesk" model="ir.module.category">
        <field name="name">CITE Helpdesk</field>
        <field name="description">Role-role CITE Helpdesk (Bab 17)</field>
        <field name="sequence">25</field>
    </record>

    <!-- ============ Security Groups (Bab 17) ============ -->
    <record id="group_it_support" model="res.groups">
        <field name="name">IT Support (Agent L1)</field>
        <field name="category_id" ref="module_category_cite_helpdesk"/>
        <field name="implied_ids" eval="[(4, ref('helpdesk.group_helpdesk_user'))]"/>
        <field name="comment">Agen helpdesk: kelola tiket, tidak bisa approve, tidak bisa hapus.</field>
    </record>

    <record id="group_infrastructure_team" model="res.groups">
        <field name="name">Infrastructure Team</field>
        <field name="category_id" ref="module_category_cite_helpdesk"/>
        <field name="implied_ids" eval="[(4, ref('group_it_support')),
                                        (4, ref('maintenance.group_equipment_manager'))]"/>
        <field name="comment">Tim infra (network/server/CCTV) + akses penuh asset Maintenance.</field>
    </record>

    <record id="group_application_team" model="res.groups">
        <field name="name">Application Team</field>
        <field name="category_id" ref="module_category_cite_helpdesk"/>
        <field name="implied_ids" eval="[(4, ref('group_it_support'))]"/>
        <field name="comment">Tim aplikasi (Odoo/software).</field>
    </record>

    <record id="group_it_administrator" model="res.groups">
        <field name="name">IT Administrator (Approver L1)</field>
        <field name="category_id" ref="module_category_cite_helpdesk"/>
        <field name="implied_ids" eval="[(4, ref('group_it_support'))]"/>
        <field name="comment">Approve/Reject Level 1, kelola master data category/subcategory/site/SLA.</field>
    </record>

    <record id="group_heidi_approver" model="res.groups">
        <field name="name">Heidi Approver (Approver L2)</field>
        <field name="category_id" ref="module_category_cite_helpdesk"/>
        <field name="implied_ids" eval="[(4, ref('helpdesk.group_helpdesk_user'))]"/>
        <field name="comment">Approver Level 2 — beranggotakan tepat satu user: Heidi Lianawaty Lisan
            (group, bukan hard-code user, agar delegasi saat cuti dimungkinkan dengan governance).</field>
    </record>

    <record id="group_it_manager" model="res.groups">
        <field name="name">IT Manager</field>
        <field name="category_id" ref="module_category_cite_helpdesk"/>
        <field name="implied_ids" eval="[(4, ref('group_it_administrator')),
                                        (4, ref('helpdesk.group_helpdesk_manager'))]"/>
        <field name="comment">Dashboard, KPI, reassign, reopen, konfigurasi team/SLA.</field>
    </record>

    <!-- ============ Record Rules (Bab 19) ============ -->
    <data noupdate="1">

        <!-- RR-03: Heidi membaca semua tiket lintas company -->
        <record id="rule_ticket_heidi_read_all" model="ir.rule">
            <field name="name">CITE: Heidi read all tickets</field>
            <field name="model_id" ref="helpdesk.model_helpdesk_ticket"/>
            <field name="groups" eval="[(4, ref('group_heidi_approver'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- RR-05: Portal hanya melihat aset yang assigned ke dirinya -->
        <record id="rule_equipment_portal_own" model="ir.rule">
            <field name="name">CITE: Portal sees own assets only</field>
            <field name="model_id" ref="maintenance.model_maintenance_equipment"/>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- RR-07: Site terlihat sesuai allowed companies (global, multi-company) -->
        <record id="rule_site_multicompany" model="ir.rule">
            <field name="name">CITE: Site multi-company</field>
            <field name="model_id" ref="model_cite_site"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False),
                                        ('company_id', 'in', company_ids)]</field>
        </record>

    </data>
</odoo>
