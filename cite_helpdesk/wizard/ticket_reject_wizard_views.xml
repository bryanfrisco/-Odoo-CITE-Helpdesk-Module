<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cite_ticket_reject_wizard_form" model="ir.ui.view">
        <field name="name">cite.ticket.reject.wizard.form</field>
        <field name="model">cite.ticket.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Ticket">
                <group>
                    <field name="ticket_id" readonly="1"/>
                    <field name="level" readonly="1"/>
                    <field name="reason"
                           placeholder="Jelaskan alasan penolakan (wajib)..."/>
                </group>
                <footer>
                    <button name="action_confirm" string="Reject" type="object"
                            class="btn-danger"/>
                    <button string="Batal" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
